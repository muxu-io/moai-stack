# moai-stack environment template.
#
# Copy to .env, fill in what you need, and `make up` picks it up via
# docker-compose's automatic .env loading. .env itself is gitignored; this
# file is the checked-in template.

# --- Postgres --------------------------------------------------------------
# Password for the `persona` DB user. persona-store builds its DATABASE_URL
# from this. Change it for anything beyond a local box.
POSTGRES_PASSWORD=persona

# --- LLM model -------------------------------------------------------------
# PERSONA_MODEL — single source of truth for the runtime LLM id. moai-stack
# owns ollama, so `make pull-model` pulls this into it. Default is
# huihui_ai/qwen3.5-abliterated:9b (refusal-ablated qwen, ~6.6 GB, tool-calling
# preserved). The authoring repo's persona-web reads the same value from its
# own .env.
PERSONA_MODEL=huihui_ai/qwen3.5-abliterated:9b

# --- GPU -------------------------------------------------------------------
# voice-svc joins the host `video` group for GPU device access. The Makefile
# derives this automatically (getent group video); set it explicitly only when
# running `docker compose` directly without make.
# VOICE_SVC_GPU_GID=44
